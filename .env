# ========= 大模型配置=========
# 阿里云百炼（免费额度多）
ALIYUN_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========= Langfuse 配置 =========
# 去 cloud.langfuse.com 注册免费账号，在"Settings → API Keys"获取
LANGFUSE_PUBLIC_KEY=pk-xxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-xxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ========= Embedding 模型（用于 Qdrant 向量化）=========
# 沿用阿里云 API Key 即可，model 名称不同
EMBEDDING_MODEL=text-embedding-v3

# ========= Qdrant 配置（本地文件模式，无需服务）=========
QDRANT_PATH=./qdrant_data          # 向量数据持久化目录
QDRANT_COLLECTION=code_review_memory